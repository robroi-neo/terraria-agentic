# Copy this file to .env and fill in the values for your environment.
# Usage: cp .env.example .env
#
# Lines prefixed with # are comments and are ignored.
# Required fields are marked [REQUIRED].
# Optional fields show their defaults and can be left commented out.

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
# Controls whether API keys are loaded and which LLM provider is used.
# Set to "production" to enable Groq API key loading.
# In "development" mode, only Ollama (local) is used and API keys are ignored.
ENV=development                         # development | production

# ---------------------------------------------------------------------------
# LLM — Local (development only)
# ---------------------------------------------------------------------------
# Used when ENV=development. Requires Ollama running locally.
# Recommended: llama3.3:70b, llama3.1:8b, or any model you have pulled.
OLLAMA_MODEL=llama3                     # e.g. llama3.3:8b


# ---------------------------------------------------------------------------
# Media Wiki API URL Endpoit
# ---------------------------------------------------------------------------
MEDIAWIKI_API_URL = "https://terraria.wiki.gg/api.php"

# ---------------------------------------------------------------------------
# LLM — Groq API (production only)
# ---------------------------------------------------------------------------
# Required when ENV=production. Get your key at https://console.groq.com
# Recommended models: meta-llama/llama-4-scout-17b-16e-instruct, llama-3.3-70b-versatile
# GROQ_API_KEY=gsk_your_key_here

# ---------------------------------------------------------------------------
# Embedder [REQUIRED]
# ---------------------------------------------------------------------------
# HuggingFace model used to embed queries and chunks for ChromaDB retrieval.
# Downloaded automatically on first run. Stored in HuggingFace cache (~400 MB).
EMBEDDER_MODEL=BAAI/bge-base-en-v1.5
# EMBEDDER_DEVICE=auto                  # auto | cpu | cuda

# ---------------------------------------------------------------------------
# Vector DB [REQUIRED]
# ---------------------------------------------------------------------------
# Path to the ChromaDB persist directory (relative to project root).
# Run the ingestion pipeline first to populate this database.
CHROMADB_PATH=./chromadb
CHROMADB_COLLECTION=terraria_wiki

# ---------------------------------------------------------------------------
# Scraper identity (recommended — be a good API citizen)
# ---------------------------------------------------------------------------
USER_AGENT=terraria-agentic/1.0 (personal RAG indexing of Terraria wiki pages; contact: your-email@example.com)
REQUEST_FROM_EMAIL=your-email@example.com

# ---------------------------------------------------------------------------
# Retrieval tuning (optional)
# ---------------------------------------------------------------------------
# RETRIEVAL_TOP_K=5                     # Number of chunks returned per query

# Enable split retrieval for walkthrough collections (set after walkthrough ingestion):
# RETRIEVAL_ENABLE_WALKTHROUGH_SPLIT=true
# RETRIEVAL_WALKTHROUGH_ROOT_COLLECTION=terraria_walkthrough_walkthrough_root
# RETRIEVAL_WALKTHROUGH_LINKS_COLLECTION=terraria_walkthrough_walkthrough_links
# RETRIEVAL_WALKTHROUGH_ROOT_DISTANCE_BONUS=0.05   # Boost root page results

# ---------------------------------------------------------------------------
# Ingestion tuning (optional)
# ---------------------------------------------------------------------------
# CHUNK_SIZE=512
# CHUNK_OVERLAP=50
# WALKTHROUGH_MAX_DEPTH=1
# WALKTHROUGH_MAX_PAGES=120
